
PORT=3000

# --- Database (PostgreSQL) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://db_user_placeholder:db_password_placeholder@db_host_placeholder:5432/veloradb?schema=public"

# --- Redis (Caching & Rate Limiting) ---
REDIS_URL="redis://redis_host_placeholder:6379"

# --- JWT Authentication Secrets ---
JWT_SECRET="replace_with_your_strong_jwt_secret_key"
JWT_REFRESH_SECRET="replace_with_your_strong_refresh_secret_key"

# --- URLs & Networking ---
BACKEND_URL="https://api.yourdomain.com/v1"

FRONTEND_URL="https://www.yourdomain.com"

# --- Email Configuration (SMTP) ---
SMTP_HOST="smtp.your_email_provider.com"
SMTP_PORT=587
SMTP_USER="your_smtp_username"
SMTP_PASS="your_smtp_password"
SMTP_FROM="noreply@yourdomain.com"

# --- Google OAuth2 (Social Login) ---
GOOGLE_CLIENT_ID="your_google_oauth_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_oauth_client_secret"
GOOGLE_CALLBACK_URL="https://api.yourdomain.com/v1/auth/google/callback"
